{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "https://sma-api.hundera.com/api/auth/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://sma-api.hundera.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
